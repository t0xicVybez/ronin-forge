{
  "name": "ronin-forge",
  "version": "1.0.0",
  "description": "Game server provisioner and setup wizard — generates configurations ready to import into Ronin Server Manager.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --windows"
  },
  "author": "PhonicSpider",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "extract-zip": "^2.0.1",
    "7zip-min": "^1.4.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.ronin.forge",
    "productName": "Ronin Forge",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Ronin Forge"
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "src/**/*",
      "node_modules/**/*"
    ]
  }
}
